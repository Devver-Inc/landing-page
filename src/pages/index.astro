---
import DeploymentTimer from "../components/custom/_utils/DeploymentTimer";
import SpeedVisualization from "../components/custom/_utils/SpeedVisualization";
import ContactSection from "../components/custom/sections/ContactSection";
import FeaturesShowcase from "../components/custom/sections/FeaturesShowcase";
import FloatingNavbar from "../components/custom/sections/FloatingNavbar";
import HeroSection from "../components/custom/sections/HeroSection";
import HowItWorksSection from "../components/custom/sections/HowItWorksSection";
import PricingSection from "../components/custom/sections/PricingSection";
import TestimonialsSection from "../components/custom/sections/TestimonialsSection";
import MainLayout from "../layouts/main.astro";

const meta = {
    title: "Devver | Deploy Test Environments Instantly",
    description: "Deploy ephemeral test environments in seconds. Let your clients and managers test features with instant preview URLs.",
};
---

<MainLayout {...meta}>
    <div class="min-h-screen">
        <!-- Floating Navbar -->
        <FloatingNavbar client:load />

        <!-- Hero Section -->
        <div class="relative">
            <HeroSection client:load />
        </div>

        <!-- Features Showcase -->
        <FeaturesShowcase client:load />

        <!-- Speed Visualization Section -->
        <section class="relative py-24 overflow-hidden">
            <div class="relative max-w-7xl mx-auto px-4">
                <div class="text-center mb-16">
                    <div class="inline-flex items-center gap-2 px-3 py-1.5 mb-6 rounded-full border border-border bg-card/70 text-xs font-medium text-muted-foreground">
                        <span class="relative flex h-2 w-2">
                            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-foreground/40 opacity-75"></span>
                            <span class="relative inline-flex rounded-full h-2 w-2 bg-foreground/60"></span>
                        </span>
                        Blazing Fast
                    </div>
                    <h2 class="text-4xl md:text-5xl font-bold text-foreground mb-4">Speed That Speaks for Itself</h2>
                    <p class="text-base text-muted-foreground max-w-2xl mx-auto">
                        Watch how fast Devver deploys your environments. No exaggeration, no tricks—just pure speed.
                    </p>
                </div>

                <div class="relative h-80 rounded-2xl glass-surface overflow-hidden">
                    <SpeedVisualization client:load />
                    <div class="absolute inset-0 flex items-center justify-center z-10">
                        <DeploymentTimer client:load />
                    </div>
                </div>

                <!-- Stats Grid -->
                <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mt-8">
                    <div class="glass-surface rounded-2xl py-6 px-6 text-center">
                        <div class="text-3xl font-bold text-foreground mb-1">99.99%</div>
                        <div class="text-xs text-muted-foreground">Uptime SLA</div>
                    </div>
                    <div class="glass-surface rounded-2xl py-6 px-6 text-center">
                        <div class="text-3xl font-bold text-foreground mb-1">&lt;1min</div>
                        <div class="text-xs text-muted-foreground">Deploy Time</div>
                    </div>
                    <div class="glass-surface rounded-2xl py-6 px-6 text-center">
                        <div class="text-3xl font-bold text-foreground mb-1">10K+</div>
                        <div class="text-xs text-muted-foreground">Developers</div>
                    </div>
                    <div class="glass-surface rounded-2xl py-6 px-6 text-center">
                        <div class="text-3xl font-bold text-foreground mb-1">1M+</div>
                        <div class="text-xs text-muted-foreground">Deployments</div>
                    </div>
                </div>
            </div>
        </section>

        <!-- How It Works Section -->
        <HowItWorksSection client:load />

        <!-- Testimonials Section -->
        <TestimonialsSection client:load />

        <!-- Pricing Section -->
        <PricingSection client:visible />

        <!-- Final CTA Section -->
        <section id="waitlist" class="relative py-24 overflow-hidden">
            <div class="relative max-w-4xl mx-auto px-4 text-center">
                <div class="inline-flex items-center gap-2 px-3 py-1.5 mb-8 rounded-full border border-border bg-card/70 text-xs font-medium text-muted-foreground">
                    <span class="relative flex h-2 w-2">
                        <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-foreground/40 opacity-75"></span>
                        <span class="relative inline-flex rounded-full h-2 w-2 bg-foreground/60"></span>
                    </span>
                    Join 10,000+ developers
                </div>

                <h2 class="text-4xl md:text-5xl font-bold text-foreground mb-4">Ready to Ship Faster?</h2>
                <p class="text-base text-muted-foreground mb-10 max-w-2xl mx-auto">Start deploying test environments in seconds. No credit card required.</p>

                <div class="flex flex-col sm:flex-row items-center justify-center gap-3 mb-10">
                    <a
                        href="https://app.devver.app"
                        class="inline-flex items-center gap-2 bg-primary text-primary-foreground rounded-md h-9 px-4 text-sm font-medium transition-all hover:opacity-90"
                    >
                        Start Free Trial
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
                        </svg>
                    </a>
                    <a href="#how-it-works" class="inline-flex items-center border border-border bg-card/70 rounded-md h-9 px-4 text-sm font-medium text-foreground hover:bg-accent transition-all">
                        See How It Works
                    </a>
                </div>

                <div class="flex items-center justify-center flex-wrap gap-6 text-xs text-muted-foreground">
                    <div class="flex items-center gap-1.5">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                        </svg>
                        No credit card required
                    </div>
                    <div class="flex items-center gap-1.5">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                        </svg>
                        14-day free trial
                    </div>
                    <div class="flex items-center gap-1.5">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                        </svg>
                        Cancel anytime
                    </div>
                </div>
            </div>
        </section>

        <!-- Contact Section -->
        <ContactSection client:load />

        <!-- Footer -->
        <footer class="border-t border-border py-10">
            <div class="max-w-7xl mx-auto px-4">
                <div class="grid md:grid-cols-4 gap-8 mb-8">
                    <div>
                        <div class="flex items-center gap-2 mb-3">
                            <img src="/favicon.png" alt="Devver Logo" class="h-7 w-7 rounded-lg" />
                            <span class="text-sm font-bold text-foreground">Devver</span>
                        </div>
                        <p class="text-xs text-muted-foreground">Deploy test environments instantly and ship faster than ever.</p>
                    </div>
                    <div>
                        <h4 class="text-sm font-semibold text-foreground mb-3">Product</h4>
                        <ul class="space-y-2 text-xs text-muted-foreground">
                            <li><a href="#features" class="hover:text-foreground transition-colors">Features</a></li>
                            <li><a href="#pricing" class="hover:text-foreground transition-colors">Pricing</a></li>
                            <li><a href="#docs" class="hover:text-foreground transition-colors">Documentation</a></li>
                            <li><a href="#" class="hover:text-foreground transition-colors">API</a></li>
                        </ul>
                    </div>
                    <div>
                        <h4 class="text-sm font-semibold text-foreground mb-3">Company</h4>
                        <ul class="space-y-2 text-xs text-muted-foreground">
                            <li><a href="#" class="hover:text-foreground transition-colors">About</a></li>
                            <li><a href="#" class="hover:text-foreground transition-colors">Blog</a></li>
                            <li><a href="#" class="hover:text-foreground transition-colors">Careers</a></li>
                            <li><a href="#" class="hover:text-foreground transition-colors">Contact</a></li>
                        </ul>
                    </div>
                    <div>
                        <h4 class="text-sm font-semibold text-foreground mb-3">Legal</h4>
                        <ul class="space-y-2 text-xs text-muted-foreground">
                            <li><a href="#" class="hover:text-foreground transition-colors">Privacy</a></li>
                            <li><a href="#" class="hover:text-foreground transition-colors">Terms</a></li>
                            <li><a href="#" class="hover:text-foreground transition-colors">Security</a></li>
                        </ul>
                    </div>
                </div>
                <div class="pt-6 border-t border-border flex flex-col md:flex-row items-center justify-between gap-4">
                    <p class="text-xs text-muted-foreground">© 2024 Devver. All rights reserved.</p>
                    <div class="flex items-center gap-4">
                        <a href="#" class="text-muted-foreground hover:text-foreground transition-colors">
                            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"></path>
                            </svg>
                        </a>
                        <a href="#" class="text-muted-foreground hover:text-foreground transition-colors">
                            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                                <path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.827 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"></path>
                            </svg>
                        </a>
                    </div>
                </div>
            </div>
        </footer>
    </div>
</MainLayout>
